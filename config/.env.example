# StoryWeaver environment variables
# Copy to .env and fill in your key.

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.xiaomimimo.com/v1
OPENAI_MODEL=mimo-v2-flash
NUM_OPTIONS=3
KG_MAX_NODES=200

# Evaluation-only LLM (Zhipu GLM-5)
EVAL_LLM_API_KEY=
EVAL_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EVAL_LLM_MODEL=glm-5
EVAL_LLM_MAX_TOKENS=256
EVAL_LLM_TEMPERATURE=0.3
